{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["trip", "days"],
  "properties": {
    "trip": {
      "type": "object",
      "required": ["id", "title", "city", "date_range", "default_center", "default_zoom"]
    },
    "days": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "short_label", "date", "title", "theme", "sun_times", "segments", "poi_entries"]
      }
    }
  }
}
